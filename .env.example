# Copy to .env and fill in ONLY the paths/keys you actually use.
# The deterministic Level-A core needs NONE of these.

# --- Local LLM (optional NLU mode: --nlu local-llm) ---
# OpenAI-compatible endpoint served locally by Ollama (`ollama serve`).
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2:1b
LOCAL_LLM_API_KEY=ollama

# --- Timezone for date/time normalization ---
VOICE_AGENT_TZ=Europe/Istanbul

# --- Local voice (Level-B) model paths ---
# Piper voice model (.onnx) + config (.onnx.json). Download separately; never commit.
PIPER_VOICE_MODEL=models/en_US-amy-medium.onnx
# faster-whisper model size (tiny/base/small). Downloaded to cache on first run.
WHISPER_MODEL=base

# --- Provider integrations (Level-C, opt-in, OFF by default) ---
# Leave blank unless you explicitly run a paid/credit-consuming provider demo.
VAPI_API_KEY=
RETELL_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
